# SmartDrop AI Environment Variables
# Copy this file to .env and fill in the values below to run locally.

# Gemini AI API Key (Get from Google AI Studio)
GEMINI_API_KEY="your_gemini_api_key_here"

# Meta WhatsApp Cloud API Access Token
META_ACCESS_TOKEN="your_meta_access_token_here"

# Meta WhatsApp Phone Number ID (Optional - defaults to TACA2WORLD)
META_PHONE_ID="1090063544188400"

# Webhook Verify Token (Must match what you enter in Meta Dashboard)
VERIFY_TOKEN="smartdrop_hackathon"
